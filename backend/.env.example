NODE_ENV=development
APP_NAME=Levi Developer Control Panel
PORT=4000
CORS_ORIGIN=http://localhost:5173,https://levi-control-panel.vercel.app
PUBLIC_BASE_URL=http://localhost:4000
DATABASE_URL=postgresql://user:password@host:5432/levi_control_panel
REDIS_URL=redis://localhost:6379
API_MONITOR_ENABLED=true
API_MONITOR_SCHEDULE=*/1 * * * *
QUEUE_NAME=automation_jobs
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=12
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=uploads
S3_PUBLIC_URL=
